{
  "name": "filemarks",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.14.4",
  "publisher": "nicegyuha",
  "author": {
    "name": "Gyuha",
    "url": "https://gyuha.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gyuha/vscode-filemarks"
  },
  "bugs": {
    "url": "https://github.com/gyuha/vscode-filemarks/issues"
  },
  "homepage": "https://github.com/gyuha/vscode-filemarks#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "bookmark",
    "bookmarks",
    "numbered bookmarks",
    "navigation",
    "filemarks",
    "code navigation",
    "folder organization",
    "productivity"
  ],
  "icon": "images/icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "filemarks",
          "title": "%viewsContainers.filemarks.title%",
          "icon": "images/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "filemarks": [
        {
          "id": "filemarks.treeView",
          "name": "%views.filemarks.treeView.name%",
          "icon": "images/sidebar-icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "filemarks.deleteSelected",
        "title": "%commands.deleteSelected.title%",
        "category": "%category.filemarks%",
        "icon": "$(remove)"
      },
      {
        "command": "filemarks.goToBookmark",
        "title": "%commands.goToBookmark.title%",
        "category": "%category.filemarks%"
      },
      {
        "command": "filemarks.deleteBookmark",
        "title": "%commands.deleteBookmark.title%",
        "category": "%category.filemarks%",
        "icon": "$(trash)"
      },
      {
        "command": "filemarks.renameBookmark",
        "title": "%commands.renameBookmark.title%",
        "category": "%category.filemarks%",
        "icon": "$(edit)"
      },
      {
        "command": "filemarks.list",
        "title": "%commands.list.title%",
        "category": "%category.filemarks%"
      },
      {
        "command": "filemarks.listAll",
        "title": "%commands.listAll.title%",
        "category": "%category.filemarks%"
      },
      {
        "command": "filemarks.createFolder",
        "title": "%commands.createFolder.title%",
        "category": "%category.filemarks%",
        "icon": "$(new-folder)"
      },
      {
        "command": "filemarks.createFolderIn",
        "title": "%commands.createFolderIn.title%",
        "category": "%category.filemarks%",
        "icon": "$(new-folder)"
      },
      {
        "command": "filemarks.deleteFolder",
        "title": "%commands.deleteFolder.title%",
        "category": "%category.filemarks%",
        "icon": "$(trash)"
      },
      {
        "command": "filemarks.renameFolder",
        "title": "%commands.renameFolder.title%",
        "category": "%category.filemarks%",
        "icon": "$(edit)"
      },
      {
        "command": "filemarks.moveToFolder",
        "title": "%commands.moveToFolder.title%",
        "category": "%category.filemarks%",
        "icon": "$(folder)"
      },
      {
        "command": "filemarks.clear",
        "title": "%commands.clear.title%",
        "category": "%category.filemarks%"
      },
      {
        "command": "filemarks.clearAll",
        "title": "%commands.clearAll.title%",
        "category": "%category.filemarks%",
        "icon": "$(trash)"
      },
      {
        "command": "filemarks.exportBookmarksJson",
        "title": "%commands.exportBookmarksJson.title%",
        "category": "%category.filemarks%"
      },
      {
        "command": "filemarks.importBookmarksJson",
        "title": "%commands.importBookmarksJson.title%",
        "category": "%category.filemarks%"
      },
      {
        "command": "filemarks.expandAllFolders",
        "title": "%commands.expandAllFolders.title%",
        "category": "%category.filemarks%",
        "icon": "$(expand-all)"
      },
      {
        "command": "filemarks.collapseAllFolders",
        "title": "%commands.collapseAllFolders.title%",
        "category": "%category.filemarks%",
        "icon": "$(collapse-all)"
      },
      {
        "command": "filemarks.focusSidebar",
        "title": "%commands.focusSidebar.title%",
        "category": "%category.filemarks%"
      },
      {
        "command": "filemarks.filter",
        "title": "%commands.filter.title%",
        "category": "%category.filemarks%",
        "icon": "$(filter)"
      },
      {
        "command": "filemarks.clearFilter",
        "title": "%commands.clearFilter.title%",
        "category": "%category.filemarks%",
        "icon": "$(close)"
      },
      {
        "command": "filemarks.toggleBookmark0",
        "title": "%commands.toggleBookmark0.title%",
        "category": "%category.filemarks%"
      },
      {
        "command": "filemarks.toggleBookmark1",
        "title": "%commands.toggleBookmark1.title%",
        "category": "%category.filemarks%"
      },
      {
        "command": "filemarks.toggleBookmark2",
        "title": "%commands.toggleBookmark2.title%",
        "category": "%category.filemarks%"
      },
      {
        "command": "filemarks.toggleBookmark3",
        "title": "%commands.toggleBookmark3.title%",
        "category": "%category.filemarks%"
      },
      {
        "command": "filemarks.toggleBookmark4",
        "title": "%commands.toggleBookmark4.title%",
        "category": "%category.filemarks%"
      },
      {
        "command": "filemarks.toggleBookmark5",
        "title": "%commands.toggleBookmark5.title%",
        "category": "%category.filemarks%"
      },
      {
        "command": "filemarks.toggleBookmark6",
        "title": "%commands.toggleBookmark6.title%",
        "category": "%category.filemarks%"
      },
      {
        "command": "filemarks.toggleBookmark7",
        "title": "%commands.toggleBookmark7.title%",
        "category": "%category.filemarks%"
      },
      {
        "command": "filemarks.toggleBookmark8",
        "title": "%commands.toggleBookmark8.title%",
        "category": "%category.filemarks%"
      },
      {
        "command": "filemarks.toggleBookmark9",
        "title": "%commands.toggleBookmark9.title%",
        "category": "%category.filemarks%"
      },
      {
        "command": "filemarks.jumpToBookmark0",
        "title": "%commands.jumpToBookmark0.title%",
        "category": "%category.filemarks%"
      },
      {
        "command": "filemarks.jumpToBookmark1",
        "title": "%commands.jumpToBookmark1.title%",
        "category": "%category.filemarks%"
      },
      {
        "command": "filemarks.jumpToBookmark2",
        "title": "%commands.jumpToBookmark2.title%",
        "category": "%category.filemarks%"
      },
      {
        "command": "filemarks.jumpToBookmark3",
        "title": "%commands.jumpToBookmark3.title%",
        "category": "%category.filemarks%"
      },
      {
        "command": "filemarks.jumpToBookmark4",
        "title": "%commands.jumpToBookmark4.title%",
        "category": "%category.filemarks%"
      },
      {
        "command": "filemarks.jumpToBookmark5",
        "title": "%commands.jumpToBookmark5.title%",
        "category": "%category.filemarks%"
      },
      {
        "command": "filemarks.jumpToBookmark6",
        "title": "%commands.jumpToBookmark6.title%",
        "category": "%category.filemarks%"
      },
      {
        "command": "filemarks.jumpToBookmark7",
        "title": "%commands.jumpToBookmark7.title%",
        "category": "%category.filemarks%"
      },
      {
        "command": "filemarks.jumpToBookmark8",
        "title": "%commands.jumpToBookmark8.title%",
        "category": "%category.filemarks%"
      },
      {
        "command": "filemarks.jumpToBookmark9",
        "title": "%commands.jumpToBookmark9.title%",
        "category": "%category.filemarks%"
      },
      {
        "command": "filemarks.jumpToPreviousBookmark",
        "title": "%commands.jumpToPreviousBookmark.title%",
        "category": "%category.filemarks%"
      },
      {
        "command": "filemarks.jumpToNextBookmark",
        "title": "%commands.jumpToNextBookmark.title%",
        "category": "%category.filemarks%"
      },
      {
        "command": "filemarks.autoBookmark",
        "title": "%commands.autoBookmark.title%",
        "category": "%category.filemarks%"
      },
      {
        "command": "filemarks.toggleBookmarkFromGutter",
        "title": "%commands.toggleBookmarkFromGutter.title%",
        "category": "%category.filemarks%",
        "icon": "$(bookmark)"
      },
      {
        "command": "filemarks.addBookmarkFromExplorer",
        "title": "%commands.addBookmarkFromExplorer.title%",
        "category": "%category.filemarks%",
        "icon": "$(bookmark)"
      }
    ],
    "keybindings": [
      {
        "command": "filemarks.toggleBookmark0",
        "key": "ctrl+alt+0",
        "mac": "cmd+alt+0",
        "when": "editorTextFocus"
      },
      {
        "command": "filemarks.toggleBookmark1",
        "key": "ctrl+alt+1",
        "mac": "cmd+alt+1",
        "when": "editorTextFocus"
      },
      {
        "command": "filemarks.toggleBookmark2",
        "key": "ctrl+alt+2",
        "mac": "cmd+alt+2",
        "when": "editorTextFocus"
      },
      {
        "command": "filemarks.toggleBookmark3",
        "key": "ctrl+alt+3",
        "mac": "cmd+alt+3",
        "when": "editorTextFocus"
      },
      {
        "command": "filemarks.toggleBookmark4",
        "key": "ctrl+alt+4",
        "mac": "cmd+alt+4",
        "when": "editorTextFocus"
      },
      {
        "command": "filemarks.toggleBookmark5",
        "key": "ctrl+alt+5",
        "mac": "cmd+alt+5",
        "when": "editorTextFocus"
      },
      {
        "command": "filemarks.toggleBookmark6",
        "key": "ctrl+alt+6",
        "mac": "cmd+alt+6",
        "when": "editorTextFocus"
      },
      {
        "command": "filemarks.toggleBookmark7",
        "key": "ctrl+alt+7",
        "mac": "cmd+alt+7",
        "when": "editorTextFocus"
      },
      {
        "command": "filemarks.toggleBookmark8",
        "key": "ctrl+alt+8",
        "mac": "cmd+alt+8",
        "when": "editorTextFocus"
      },
      {
        "command": "filemarks.toggleBookmark9",
        "key": "ctrl+alt+9",
        "mac": "cmd+alt+9",
        "when": "editorTextFocus"
      },
      {
        "command": "filemarks.jumpToBookmark0",
        "key": "ctrl+0",
        "mac": "cmd+0",
        "when": "editorTextFocus"
      },
      {
        "command": "filemarks.jumpToBookmark1",
        "key": "ctrl+1",
        "mac": "cmd+1",
        "when": "editorTextFocus"
      },
      {
        "command": "filemarks.jumpToBookmark2",
        "key": "ctrl+2",
        "mac": "cmd+2",
        "when": "editorTextFocus"
      },
      {
        "command": "filemarks.jumpToBookmark3",
        "key": "ctrl+3",
        "mac": "cmd+3",
        "when": "editorTextFocus"
      },
      {
        "command": "filemarks.jumpToBookmark4",
        "key": "ctrl+4",
        "mac": "cmd+4",
        "when": "editorTextFocus"
      },
      {
        "command": "filemarks.jumpToBookmark5",
        "key": "ctrl+5",
        "mac": "cmd+5",
        "when": "editorTextFocus"
      },
      {
        "command": "filemarks.jumpToBookmark6",
        "key": "ctrl+6",
        "mac": "cmd+6",
        "when": "editorTextFocus"
      },
      {
        "command": "filemarks.jumpToBookmark7",
        "key": "ctrl+7",
        "mac": "cmd+7",
        "when": "editorTextFocus"
      },
      {
        "command": "filemarks.jumpToBookmark8",
        "key": "ctrl+8",
        "mac": "cmd+8",
        "when": "editorTextFocus"
      },
      {
        "command": "filemarks.jumpToBookmark9",
        "key": "ctrl+9",
        "mac": "cmd+9",
        "when": "editorTextFocus"
      },
      {
        "command": "filemarks.focusSidebar",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b"
      },
      {
        "command": "filemarks.jumpToPreviousBookmark",
        "key": "ctrl+alt+[",
        "mac": "cmd+alt+[",
        "when": "editorTextFocus"
      },
      {
        "command": "filemarks.jumpToNextBookmark",
        "key": "ctrl+alt+]",
        "mac": "cmd+alt+]",
        "when": "editorTextFocus"
      },
      {
        "command": "filemarks.autoBookmark",
        "key": "ctrl+alt+p",
        "mac": "cmd+alt+p",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "%configuration.title%",
      "properties": {
        "filemarks.autoReveal": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.autoReveal.description%"
        },
        "filemarks.saveBookmarksInProject": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.saveBookmarksInProject.description%"
        },
        "filemarks.navigateThroughAllFiles": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.navigateThroughAllFiles.description%"
        },
        "filemarks.showBookmarkNotDefinedWarning": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.showBookmarkNotDefinedWarning.description%"
        },
        "filemarks.revealLocation": {
          "type": "string",
          "enum": [
            "top",
            "center"
          ],
          "default": "center",
          "description": "%configuration.revealLocation.description%"
        },
        "filemarks.gutterIconFillColor": {
          "type": "string",
          "default": "#FBC74F",
          "description": "%configuration.gutterIconFillColor.description%"
        },
        "filemarks.gutterIconNumberColor": {
          "type": "string",
          "default": "#A05A14",
          "description": "%configuration.gutterIconNumberColor.description%"
        }
      }
    },
    "configurationDefaults": {
      "workbench.tree.indent": 22,
      "workbench.tree.enableStickyScroll": true,
      "workbench.hover.delay": 75
    },
    "viewsWelcome": [
      {
        "view": "filemarks.treeView",
        "contents": "%viewsWelcome.filemarks.treeView.empty.contents%",
        "when": "!filemarks.hasFilter"
      },
      {
        "view": "filemarks.treeView",
        "contents": "%viewsWelcome.filemarks.treeView.filtered.contents%",
        "when": "filemarks.hasFilter"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "filemarks.filter",
          "when": "view == filemarks.treeView && !filemarks.hasFilter",
          "group": "navigation@0"
        },
        {
          "command": "filemarks.clearFilter",
          "when": "view == filemarks.treeView && filemarks.hasFilter",
          "group": "navigation@0"
        },
        {
          "command": "filemarks.createFolder",
          "when": "view == filemarks.treeView",
          "group": "navigation@1"
        },
        {
          "command": "filemarks.expandAllFolders",
          "when": "view == filemarks.treeView",
          "group": "navigation@2"
        },
        {
          "command": "filemarks.collapseAllFolders",
          "when": "view == filemarks.treeView",
          "group": "navigation@3"
        },
        {
          "command": "filemarks.deleteSelected",
          "when": "view == filemarks.treeView",
          "group": "navigation@4"
        },
        {
          "command": "filemarks.clearAll",
          "when": "view == filemarks.treeView",
          "group": "navigation@5"
        }
      ],
      "view/item/context": [
        {
          "command": "filemarks.createFolderIn",
          "when": "view == filemarks.treeView && viewItem == folder",
          "group": "navigation"
        },
        {
          "command": "filemarks.goToBookmark",
          "when": "view == filemarks.treeView && viewItem == bookmark",
          "group": "navigation"
        },
        {
          "command": "filemarks.renameBookmark",
          "when": "view == filemarks.treeView && viewItem == bookmark",
          "group": "edit@1"
        },
        {
          "command": "filemarks.moveToFolder",
          "when": "view == filemarks.treeView && viewItem == bookmark",
          "group": "edit@2"
        },
        {
          "command": "filemarks.deleteBookmark",
          "when": "view == filemarks.treeView && viewItem == bookmark",
          "group": "edit@3"
        },
        {
          "command": "filemarks.renameFolder",
          "when": "view == filemarks.treeView && viewItem == folder",
          "group": "edit@1"
        },
        {
          "command": "filemarks.deleteFolder",
          "when": "view == filemarks.treeView && viewItem == folder",
          "group": "edit@2"
        }
      ],
      "editor/lineNumber/context": [
        {
          "command": "filemarks.toggleBookmarkFromGutter",
          "group": "filemarks@1"
        },
        {
          "command": "filemarks.clear",
          "group": "filemarks@2"
        }
      ],
      "explorer/context": [
        {
          "command": "filemarks.addBookmarkFromExplorer",
          "when": "!explorerResourceIsFolder",
          "group": "filemarks"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "node esbuild.js --production",
    "compile:esbuild": "node esbuild.js",
    "watch:esbuild": "node esbuild.js --watch",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "node ./dist/test/runTest.js",
    "vsce:package": "npx @vscode/vsce@3.7.1 package --no-dependencies",
    "vsce:publish": "npx @vscode/vsce@3.7.1 publish --no-dependencies"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.x",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "glob": "^13.0.0",
    "mocha": "^11.7.5",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "uuid": "^13.0.0"
  }
}
